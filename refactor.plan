# ============================================================
# DEPENDENCY GRAPH (extraction order rationale)
# ============================================================
#
# constants.js ← (nothing — leaf)
# state.js     ← constants.js
# audio.js     ← (self-contained, no game imports)
# weather.js   ← state.js, constants.js
# night.js     ← state.js, constants.js, THREE
# difficulty.js← state.js, constants.js, weather.js, night.js
# collisions.js← state.js, constants.js, audio.js
# vehicles.js  ← state.js, constants.js, audio.js, night.js, THREE
# pedestrians.js← state.js, constants.js, THREE
# scene.js     ← state.js, constants.js, THREE
# gestures.js  ← state.js, constants.js, main.js (circular — use late binding)
# controls.js  ← state.js, constants.js, main.js (circular — use late binding)
# main.js      ← everything
#
# Circular dependency resolution:
#   gestures.js and controls.js need startGame/resetToStartScreen from main.js
#   main.js needs initGestureDetection from gestures.js
#   → Solution: main.js passes callbacks after import
#     e.g., import { setCallbacks } from './gestures.js';
#           setCallbacks({ startGame, resetToStartScreen });
#   This avoids circular `import` at module evaluation time.

# ============================================================
# ROLLBACK PLAN
# ============================================================
#
# Every extraction step is a separate commit.  If something breaks:
#   git revert HEAD      — undo last extraction
#   node tests.js        — verify green
#   npx playwright test  — verify e2e
#
# If the whole refactor needs to be abandoned:
#   git reset --hard pre-refactor
#
# The pre-refactor tag preserves the known-good single-file state.

